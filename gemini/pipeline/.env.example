# GEMINI Database Configuration
GEMINI_DB_CONTAINER_NAME=geminibase-db
GEMINI_DB_IMAGE_NAME=geminibase/db
GEMINI_DB_USER=gemini
GEMINI_DB_PASSWORD=gemini
GEMINI_DB_HOSTNAME=geminibase-db
GEMINI_DB_NAME=gemini
GEMINI_DB_PORT=5432

# GEMINI Logger Configuration
GEMINI_LOGGER_CONTAINER_NAME=geminibase-logger
GEMINI_LOGGER_IMAGE_NAME=geminibase/logger
GEMINI_LOGGER_HOSTNAME=geminibase-logger
GEMINI_LOGGER_PORT=6379
GEMINI_LOGGER_PASSWORD=gemini

# GEMINI File Store
GEMINI_STORAGE_CONTAINER_NAME=geminibase-storage
GEMINI_STORAGE_IMAGE_NAME=geminibase/storage
GEMINI_STORAGE_HOSTNAME=geminibase-storage
GEMINI_STORAGE_PORT=9000
GEMINI_STORAGE_API_PORT=9001
GEMINI_STORAGE_ROOT_USER=gemini_root
GEMINI_STORAGE_ROOT_PASSWORD=gemini_root
GEMINI_STORAGE_ACCESS_KEY=gemini_storage_user
GEMINI_STORAGE_SECRET_KEY=gemini_secret
GEMINI_STORAGE_BUCKET_NAME=gemini

# TiTiler (tile server for COGs stored in MinIO)
GEMINI_TITILER_PORT=8091

# NodeODM (OpenDroneMap processing service)
GEMINI_NODEODM_PORT=13000

# REST API Configuration
GEMINI_REST_API_CONTAINER_NAME=geminibase-rest-api
GEMINI_REST_API_IMAGE_NAME=geminibase/rest-api
GEMINI_REST_API_HOSTNAME=geminibase-rest-api
GEMINI_REST_API_PORT=7777

# Reverse Proxy
GEMINI_REVERSE_PROXY_CONTAINER_NAME=geminibase-reverse-proxy
GEMINI_REVERSE_PROXY_IMAGE_NAME=geminibase/reverse-proxy
GEMINI_REVERSE_PROXY_HOSTNAME=geminibase-reverse-proxy
